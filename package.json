{
  "name": "studybuddy-project",
  "version": "1.0.0",
  "description": "StudyBuddy Full-Stack Educational Application",
  "scripts": {
    "install-all": "npm install --legacy-peer-deps && npm --prefix backend install --legacy-peer-deps && npm --prefix frontend install --legacy-peer-deps",
    "start-backend": "npm --prefix backend run dev",
    "start-frontend": "npm --prefix frontend run dev",
    "dev": "concurrently \"npm run start-backend\" \"npm run start-frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
